---
import Layout from '../components/Layout.astro';
import { verifyToken } from '../lib/auth';
import MailComposer from '../components/MailComposer.jsx';

const isAuthed = verifyToken(Astro.request);
if (!isAuthed) {
  return Astro.redirect('/login');
}
---

<Layout title="Mail Client">
  <div class="flex flex-col min-h-screen bg-background font-sans">
    
    <!-- 极简标准顶栏 -->
    <header class="border-b border-border bg-background px-6 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">

        <div class="flex items-center gap-4">
            <!-- 正方形 Logo 位 -->
            <div class="w-8 h-8 bg-foreground text-background flex items-center justify-center font-bold text-lg">
                M
            </div>
            <div>
                <h1 class="text-lg font-semibold text-foreground leading-tight">Mail Client</h1>
                <p class="text-xs text-muted-foreground">Workspace / Compose</p>
            </div>
        </div>

        <div class="flex items-center gap-6 text-sm">
            <div class="flex items-center gap-2">
                <!-- 方块在线指示灯 -->
                <div class="w-2 h-2 bg-green-500"></div>
                <span class="text-muted-foreground">System Online</span>
            </div>
            <div class="hidden sm:block w-px h-4 bg-border"></div>
            <div class="font-mono text-xs text-muted-foreground hidden sm:block">
                ID: ROOT_USER
            </div>
        </div>
    </header>

    <main class="flex-1 p-0 sm:p-6 bg-muted/10">
        <div class="mx-auto h-full">
            <MailComposer client:only="react" />
        </div>
    </main>
  </div>
</Layout>