---
import Layout from '../components/Layout.astro';
import { verifyToken } from '../lib/auth';
import MailComposer from '../components/MailComposer.jsx';

const isAuthed = verifyToken(Astro.request);
if (!isAuthed) {
  return Astro.redirect('/login');
}
---

<Layout title="Terminal">
  <div class="flex flex-col min-h-screen border-x border-border">
    
    <header class="border-b border-border bg-card p-6 sm:p-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 relative overflow-hidden">

        <div class="z-10">
            <div class="flex items-center gap-3 mb-2">
                <span class="w-3 h-3 bg-primary block"></span>
                <span class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest">Protocol V.1.0</span>
            </div>
            <h1 class="text-5xl sm:text-6xl font-mono font-black tracking-tighter text-foreground uppercase leading-[0.9]">
                SMTP<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-foreground to-foreground/50">Uplink</span>
            </h1>
        </div>

        <div class="flex flex-col items-start md:items-end z-10">
            <div class="flex gap-4 text-[10px] font-mono border border-border p-2 bg-background">
                <div class="flex flex-col px-2 border-r border-border">
                    <span class="text-muted-foreground">STATUS</span>
                    <span class="font-bold text-primary">ONLINE</span>
                </div>
                <div class="flex flex-col px-2 border-r border-border">
                    <span class="text-muted-foreground">LATENCY</span>
                    <span class="font-bold">24ms</span>
                </div>
                <div class="flex flex-col px-2">
                    <span class="text-muted-foreground">USER</span>
                    <span class="font-bold">ROOT</span>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-1 p-0 relative bg-background">
        <MailComposer client:only="react" />
    </main>
  </div>
</Layout>