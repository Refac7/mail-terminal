---
import Layout from '../components/Layout.astro';
import { verifyToken } from '../lib/auth';

if (verifyToken(Astro.request)) {
  return Astro.redirect('/');
}
---

<Layout title="Auth">
  <div class="min-h-screen w-full flex flex-col md:flex-row bg-background font-mono overflow-hidden">
    
    <div class="relative w-full md:w-1/2 h-[30vh] md:h-auto bg-muted/10 border-b md:border-b-0 md:border-r-2 border-border flex flex-col justify-between p-6 md:p-12 overflow-hidden group select-none">
        
        <div class="absolute inset-0 z-0 opacity-[0.03]" 
             style="background-image: linear-gradient(currentColor 1px, transparent 1px), linear-gradient(90deg, currentColor 1px, transparent 1px); background-size: 20px 20px;">
        </div>
        
        <div class="relative z-10 text-[10px] text-muted-foreground uppercase tracking-widest flex items-center gap-2">
            <span class="w-2 h-2 bg-primary animate-pulse"></span>
            SYS.CONFIG.V2 // SECURE
        </div>

        <div class="relative z-10 space-y-2 md:space-y-4 mt-4 md:mt-0">
            <h1 class="text-4xl md:text-7xl font-black uppercase tracking-tighter leading-[0.9] text-foreground/90">
                Mail terminal<br/>
                System Locked
            </h1>
            <p class="text-xs md:text-sm text-muted-foreground uppercase tracking-widest border-l-2 border-primary pl-3">
                Restricted Area // Auth Required
            </p>
        </div>

        <div class="relative z-10 hidden md:flex justify-between items-end text-[10px] text-muted-foreground">
            <div class="flex flex-col gap-1">
                <span>LAT: 00.00.00</span>
                <span>LON: 00.00.00</span>
            </div>
            <div class="text-right">
                NO UNAUTHORIZED<br>ACCESS PERMITTED
            </div>
        </div>
        
        <div class="relative z-10 md:hidden text-[10px] text-muted-foreground text-right">
            SECURE.GATEWAY
        </div>
    </div>

    <div class="w-full md:w-1/2 flex-1 flex flex-col items-center justify-center p-6 md:p-12 relative bg-card/50">
        
        <div class="absolute top-4 right-4 md:top-8 md:right-8 text-[10px] text-muted-foreground border border-border px-2 py-1">
            ID: 884-XJ-02
        </div>

        <div class="w-full max-w-sm space-y-8 relative">
            
            <div class="md:hidden space-y-1">
                <h2 class="text-xl font-bold uppercase tracking-tight">Access Control</h2>
                <div class="h-1 w-12 bg-primary"></div>
            </div>

            <form id="login-form" class="space-y-8">
                <div class="relative group">
                    <div class="flex justify-between items-end mb-2">
                        <label for="password" class="text-[10px] font-bold font-mono text-foreground bg-foreground/5 px-2 py-0.5">PASSCODE INPUT</label>
                        <span class="text-[9px] text-muted-foreground">ENCRYPTION: AES-256</span>
                    </div>
                    
                    <div class="relative">
                        <input 
                            type="password" 
                            id="password" 
                            placeholder="••••••••"
                            class="w-full bg-background border-2 border-border p-4 text-center font-mono text-xl tracking-[0.5em] placeholder:tracking-normal focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-all shadow-sm" 
                        />
                        <div class="absolute top-0 left-0 w-2 h-2 border-t-2 border-l-2 border-foreground opacity-30"></div>
                        <div class="absolute bottom-0 right-0 w-2 h-2 border-b-2 border-r-2 border-foreground opacity-30"></div>
                    </div>
                </div>
                
                <button type="submit" class="w-full py-5 bg-foreground text-background font-mono font-bold text-sm uppercase tracking-[0.2em] hover:bg-primary hover:text-white transition-all border-2 border-transparent relative overflow-hidden group active:scale-[0.98]">
                    <span class="relative z-10 flex items-center justify-center gap-2">
                        Initialize Session
                        <span class="hidden group-hover:inline-block transition-transform group-hover:translate-x-1">-></span>
                    </span>
                    <div class="absolute inset-0 bg-primary/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
                </button>
                
                <div class="h-6 flex items-center justify-center">
                    <p id="error-msg" class="text-[10px] font-mono text-red-500 bg-red-500/10 border border-red-500/20 px-3 py-1 uppercase opacity-0 transition-opacity flex items-center gap-2">
                        <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
                        Error: Invalid Credentials
                    </p>
                </div>
            </form>

            <div class="pt-8 border-t border-dashed border-border flex justify-center text-[10px] text-muted-foreground uppercase">
                <span class="hover:text-foreground cursor-help transition-colors">Contact Administrator</span>
            </div>
        </div>
    </div>
  </div>

<script>
    const form = document.getElementById('login-form');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const msg = document.getElementById('error-msg');
        if (!passwordInput || !msg) return;

        try {
            const res = await fetch('/api/auth/login', {
                method: 'POST',
                body: JSON.stringify({ password: passwordInput.value })
            });
            if (res.ok) {
                window.location.href = '/';
            } else {
                msg.classList.remove('opacity-0');
                passwordInput.classList.add('border-red-500', 'text-red-500');
                setTimeout(() => {
                    msg.classList.add('opacity-0');
                    passwordInput.classList.remove('border-red-500', 'text-red-500');
                }, 2000);
            }
        } catch (err) {
            console.error(err);
        }
    });
</script>
</Layout>