---
import Layout from '../components/Layout.astro';
import { verifyToken } from '../lib/auth';

if (verifyToken(Astro.request)) {
  return Astro.redirect('/');
}
---

<Layout title="Sign In">
  <div class="min-h-screen w-full flex flex-col md:flex-row bg-background font-sans overflow-hidden">
    
    <!-- 左侧：品牌/展示区 -->
    <div class="relative w-full md:w-5/12 h-[30vh] md:h-auto bg-muted/20 border-b md:border-b-0 md:border-r border-border flex flex-col justify-between p-8 md:p-16 select-none">
        
        <!-- 极简背景网格 -->
        <div class="absolute inset-0 z-0 opacity-[0.04]" 
             style="background-image: linear-gradient(currentColor 1px, transparent 1px), linear-gradient(90deg, currentColor 1px, transparent 1px); background-size: 32px 32px;">
        </div>
        
        <div class="relative z-10 text-xs font-mono text-muted-foreground flex items-center gap-3">
            <!-- 方块指示灯，替代圆点 -->
            <div class="w-2 h-2 bg-primary"></div>
            Workspace
        </div>

        <div class="relative z-10 space-y-4 mt-8 md:mt-0">
            <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-foreground">
                Welcome back.
            </h1>
            <p class="text-base text-muted-foreground max-w-sm">
                Sign in to your account to access the secure mail client and manage your communications.
            </p>
        </div>

        <div class="relative z-10 hidden md:flex justify-between items-end text-xs font-mono text-muted-foreground">
            <div>v2.0.4 Release</div>
        </div>
    </div>

    <!-- 右侧：登录表单区 -->
    <div class="w-full md:w-7/12 flex-1 flex flex-col items-center justify-center p-8 md:p-16 relative bg-background">
        
        <div class="w-full max-w-sm space-y-8 relative">
            
            <div class="space-y-2">
                <h2 class="text-2xl font-semibold tracking-tight">Sign In</h2>
                <p class="text-sm text-muted-foreground">Enter your passcode to continue.</p>
            </div>

            <form id="login-form" class="space-y-6">
                <div class="space-y-2">
                    <label for="password" class="text-sm font-medium text-foreground">
                        Passcode
                    </label>
                    <div class="relative">
                        <!-- 全直角输入框 -->
                        <input 
                            type="password" 
                            id="password" 
                            placeholder="Enter your passcode"
                            class="w-full bg-background border border-border p-3 text-sm focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition-colors" 
                        />
                    </div>
                </div>
                
                <!-- 全直角按钮 -->
                <button type="submit" class="w-full py-3 bg-foreground text-background font-medium text-sm hover:bg-primary hover:text-white transition-colors flex items-center justify-center gap-2 group">
                    Continue
                    <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
                </button>
                
                <!-- 错误提示（直角，方块指示灯） -->
                <div class="h-10 flex items-center">
                    <div id="error-msg" class="w-full text-sm text-red-600 bg-red-500/10 border border-red-500/20 px-4 py-2 opacity-0 transition-opacity flex items-center gap-3">
                        <div class="w-1.5 h-1.5 bg-red-600"></div>
                        Invalid credentials. Please try again.
                    </div>
                </div>
            </form>

            <div class="pt-6 border-t border-border flex justify-start text-sm text-muted-foreground">
                <a href="#" class="hover:text-foreground transition-colors underline underline-offset-4 decoration-border hover:decoration-foreground">Need help?</a>
            </div>
        </div>
    </div>
  </div>

<script>
    const form = document.getElementById('login-form');
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const msg = document.getElementById('error-msg');
        if (!passwordInput || !msg) return;

        try {
            const res = await fetch('/api/auth/login', {
                method: 'POST',
                body: JSON.stringify({ password: passwordInput.value })
            });
            if (res.ok) {
                window.location.href = '/';
            } else {
                msg.classList.remove('opacity-0');
                passwordInput.classList.add('border-red-500');
                setTimeout(() => {
                    msg.classList.add('opacity-0');
                    passwordInput.classList.remove('border-red-500');
                }, 3000);
            }
        } catch (err) {
            console.error(err);
        }
    });
</script>
</Layout>