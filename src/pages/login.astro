---
import Layout from '../components/Layout.astro';
import { verifyToken } from '../lib/auth';

if (verifyToken(Astro.request)) {
  return Astro.redirect('/');
}
---

<Layout title="Access Control">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="w-full max-w-md border border-border p-8 relative overflow-hidden group">
       
       <div class="absolute top-0 inset-x-0 h-1 bg-primary transform origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>

       <div class="mb-8">
         <h2 class="text-2xl font-bold font-mono uppercase tracking-tighter mb-2">Identity Verify</h2>
         <p class="text-xs text-muted-foreground font-mono">Input credentials to access SMTP Uplink.</p>
       </div>

       <form id="login-form" class="space-y-6">
          <div>
             <label class="block text-[10px] uppercase font-mono tracking-widest mb-2 text-muted-foreground">Passcode</label>
             <input type="password" id="password" class="w-full bg-muted/5 border border-border p-3 text-center tracking-[0.5em] font-mono focus:border-primary focus:outline-none transition-colors text-xl" />
          </div>
          <button type="submit" class="w-full py-4 bg-foreground text-background font-mono font-bold uppercase tracking-widest hover:bg-primary transition-colors">
             Initialize
          </button>
          <p id="error-msg" class="text-xs font-mono text-red-500 text-center h-4 opacity-0 transition-opacity">ACCESS_DENIED</p>
       </form>
    </div>
  </div>

<script>
    const form = document.getElementById('login-form');
    
    form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // 类型断言：告诉 TS 这是一个 Input 元素
    const passwordInput = document.getElementById('password') as HTMLInputElement;
    const msg = document.getElementById('error-msg');
    
    if (!passwordInput || !msg) return;

    const pwd = passwordInput.value;
    
    try {
        const res = await fetch('/api/auth/login', {
            method: 'POST',
            body: JSON.stringify({ password: pwd })
        });
        if (res.ok) {
            window.location.href = '/';
        } else {
            msg.classList.remove('opacity-0');
            setTimeout(() => msg.classList.add('opacity-0'), 2000);
        }
    } catch (err) {
        console.error(err);
    }
    });
</script>
</Layout>